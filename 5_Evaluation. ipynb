        "def evaluate_win_rate_hf(\n",
        "    model_a_outputs, model_b_outputs, prompts,\n",
        "    model_a_name=\"A\", model_b_name=\"B\", hf_token=None,\n",
        ") -> dict:\n",
        "    from huggingface_hub import InferenceClient\n",
