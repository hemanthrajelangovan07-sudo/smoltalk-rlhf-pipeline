        "def _numbers_equal(pred: str, true: str) -> bool:\n",
        "    if pred is None or true is None:\n",
        "        return False\n",
        "    try:\n",
        "        return Decimal(pred) == Decimal(true)\n",
        "    except InvalidOperation:\n",
        "        try:\n",
        "            return abs(float(pred) - float(true)) < 1e-6\n",
        "        except (ValueError, TypeError):\n",
        "            return False\n"
      ],
      "metadata": {
